<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="driver_maui.Pages.ScheduleLessonPage"
             Title="Schedule Lesson">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="10">
            <Button Text="Back" Clicked="Back_Click" HorizontalOptions="Start" WidthRequest="80"/>
            <Label Text="Book a Lesson" FontSize="20" FontAttributes="Bold"/>
            <Label x:Name="TeacherLabel" TextColor="Gray"/>

            <Label Text="Pick a date:" FontAttributes="Bold"/>
            <DatePicker x:Name="DatePicker1" Format="dd/MM/yyyy" DateSelected="DatePicker1_DateSelected"/>

            <Label Text="Available times:" FontAttributes="Bold"/>
            <Picker x:Name="TimePicker1" Title="Select a time"/>
            <Label x:Name="NoTimesLabel" TextColor="OrangeRed" IsVisible="False"
                   Text="No available times for this date."/>

            <Button Text="Book Lesson" Clicked="Book_Click" BackgroundColor="#4CAF50"/>
            <Label x:Name="ResultLabel" IsVisible="False"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
