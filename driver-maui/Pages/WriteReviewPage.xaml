<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="driver_maui.Pages.WriteReviewPage"
             Title="Write Review">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="10">
            <Button Text="Back" Clicked="Back_Click" HorizontalOptions="Start" WidthRequest="80"/>
            <Label Text="Rate Your Teacher" FontSize="20" FontAttributes="Bold"/>
            <Label x:Name="TeacherLabel" TextColor="Gray"/>

            <Label Text="Rating (1-5):" FontAttributes="Bold"/>
            <Picker x:Name="RatingPicker" Title="Select rating">
                <Picker.Items>
                    <x:String>5 - Excellent</x:String>
                    <x:String>4 - Good</x:String>
                    <x:String>3 - Average</x:String>
                    <x:String>2 - Poor</x:String>
                    <x:String>1 - Terrible</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Review:" FontAttributes="Bold"/>
            <Editor x:Name="ReviewEditor" Placeholder="Share your experience..." HeightRequest="120" MaxLength="500"/>

            <Button Text="Submit Review" Clicked="Submit_Click" BackgroundColor="#9C27B0"/>
            <Label x:Name="ResultLabel" IsVisible="False"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
