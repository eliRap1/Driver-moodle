<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="driver_maui.Pages.PaymentReportsPage"
             Title="Payment Reports">
    <VerticalStackLayout Padding="15" Spacing="12">
        <Button Text="Back" Clicked="Back_Click" HorizontalOptions="Start" WidthRequest="80"/>
        <Border BackgroundColor="#F5F5F5" Padding="15"><Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
            <VerticalStackLayout Spacing="6">
                <Label x:Name="TotalEarningsLabel" FontSize="18" FontAttributes="Bold"/>
                <Label x:Name="ThisMonthLabel" FontSize="15"/>
                <Label x:Name="PendingLabel" FontSize="15" TextColor="OrangeRed"/>
            </VerticalStackLayout>
        </Border>
        <Label Text="Recent Payments" FontAttributes="Bold" FontSize="14"/>
        <CollectionView x:Name="RecentList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,3" Padding="10"><Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*,Auto">
                            <Label Grid.Column="0" Text="{Binding DateText}"/>
                            <Label Grid.Column="1" Text="{Binding Method}" TextColor="Gray"/>
                            <Label Grid.Column="2" Text="{Binding AmountText}" FontAttributes="Bold" TextColor="#4CAF50"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
