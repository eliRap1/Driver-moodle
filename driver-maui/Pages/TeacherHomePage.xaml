<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="driver_maui.Pages.TeacherHomePage"
             Title="Teacher Dashboard">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label x:Name="WelcomeLabel" FontSize="20" FontAttributes="Bold"/>
            <Label x:Name="AdminBadge" Text="ADMIN" TextColor="White" BackgroundColor="Red"
                   IsVisible="False" HorizontalOptions="Start" Padding="8,3" FontAttributes="Bold"/>
            <Label x:Name="StatusLabel" TextColor="Red" FontSize="13" IsVisible="False"/>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Border Grid.Column="0" BackgroundColor="#2196F3" Padding="12"><Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label x:Name="StudentsCountLabel" Text="0" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                        <Label Text="Students" TextColor="White" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="#4CAF50" Padding="12"><Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label x:Name="TodayLessonsLabel" Text="0" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                        <Label Text="Today" TextColor="White" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" BackgroundColor="#FF9800" Padding="12"><Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label x:Name="UnpaidCountLabel" Text="0" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                        <Label Text="Unpaid" TextColor="White" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Button Text="Confirm Payments" Clicked="ConfirmPayments_Click" BackgroundColor="#FF9800"/>
            <Button Text="Payment Reports" Clicked="PaymentReports_Click" BackgroundColor="#2196F3"/>
            <Button Text="Notifications" Clicked="Notifications_Click" BackgroundColor="#9C27B0"/>
            <Button Text="Chat" Clicked="Chat_Click" BackgroundColor="#009688"/>
            <Button Text="Logout" Clicked="Logout_Click" BackgroundColor="#757575"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
