<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="driver_maui.Pages.ConfirmPaymentsPage"
             Title="Confirm Payments">
    <VerticalStackLayout Padding="15" Spacing="10">
        <Button Text="Back" Clicked="Back_Click" HorizontalOptions="Start" WidthRequest="80"/>
        <Label Text="Unpaid Lessons" FontAttributes="Bold" FontSize="16"/>
        <Label x:Name="ResultLabel" IsVisible="False"/>
        <CollectionView x:Name="LessonsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4" Padding="12"><Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding StudentName}" FontAttributes="Bold"/>
                                <Label Text="{Binding DateTimeText}" TextColor="Gray" FontSize="13"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="Confirm Paid"
                                    CommandParameter="{Binding LessonId}"
                                    Clicked="ConfirmBtn_Click"
                                    BackgroundColor="#4CAF50"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
