<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="driver_maui.Pages.NotificationsPage"
             Title="Notifications">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="10">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="Back" Clicked="Back_Click" WidthRequest="80"/>
                <Button Grid.Column="1" Text="Mark All Read" Clicked="MarkAllRead_Click"
                        BackgroundColor="#757575" HorizontalOptions="End"/>
            </Grid>

            <Border Padding="12" BackgroundColor="#F5F5F5">
                <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Send Message" FontAttributes="Bold" FontSize="16"/>
                    <Picker x:Name="RecipientPicker" Title="Select recipient"/>
                    <Entry x:Name="TitleEntry" Placeholder="Title" MaxLength="100"/>
                    <Editor x:Name="MessageEditor" Placeholder="Message" HeightRequest="80" MaxLength="500"/>
                    <Button Text="Send" Clicked="Send_Click" BackgroundColor="#2196F3"/>
                    <Label x:Name="SendStatusLabel" IsVisible="False" FontSize="12"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Inbox" FontAttributes="Bold" FontSize="16" Margin="0,8,0,0"/>
            <CollectionView x:Name="NotifList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,3" Padding="12"
                               BackgroundColor="{Binding BgColor}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Title}" FontAttributes="Bold"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding Message}" FontSize="13"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="{Binding TimeText}" FontSize="11" TextColor="Gray"/>
                                <VerticalStackLayout Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                                                     Spacing="4" VerticalOptions="Center">
                                    <Button Text="Read"
                                            CommandParameter="{Binding NotificationId}"
                                            Clicked="MarkRead_Click"
                                            FontSize="10" Padding="6,2"
                                            BackgroundColor="#4CAF50"
                                            IsVisible="{Binding ShowMarkRead}"/>
                                    <Button Text="Delete"
                                            CommandParameter="{Binding NotificationId}"
                                            Clicked="Delete_Click"
                                            FontSize="10" Padding="6,2"
                                            BackgroundColor="#F44336"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
