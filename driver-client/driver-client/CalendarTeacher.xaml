<Page x:Class="driver_client.CalendarTeacher"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1040"
      Title="CalendarTeacher"
      Background="#0E1A2B">

    <Grid>
        <Image Source="/picture/background.png"
               Stretch="UniformToFill"
               Opacity="0.08"
               Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1" Margin="24" MaxWidth="1120" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="Back"
                        Style="{StaticResource PrimaryButton}"
                        Width="96"
                        Height="38"
                        FontSize="14"
                        Margin="0"
                        Click="BackButton_Click"/>

                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <TextBlock Text="Availability calendar"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#00E0FF"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Set the normal teaching week, then add exceptions for blocked or special working days."
                               FontSize="14"
                               Foreground="#AAB7C8"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                <TabControl Background="#14273D"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="12">
                    <TabItem Header="Weekly hours">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="Teaching days" Style="{StaticResource SectionTitle}"/>
                                <WrapPanel Margin="0,4,0,18">
                                    <CheckBox Content="Monday" x:Name="MondayCheck" Foreground="White" Margin="0,0,18,10"/>
                                    <CheckBox Content="Tuesday" x:Name="TuesdayCheck" Foreground="White" Margin="0,0,18,10"/>
                                    <CheckBox Content="Wednesday" x:Name="WednesdayCheck" Foreground="White" Margin="0,0,18,10"/>
                                    <CheckBox Content="Thursday" x:Name="ThursdayCheck" Foreground="White" Margin="0,0,18,10"/>
                                    <CheckBox Content="Friday" x:Name="FridayCheck" Foreground="White" Margin="0,0,18,10"/>
                                    <CheckBox Content="Saturday" x:Name="SaturdayCheck" Foreground="White" Margin="0,0,18,10"/>
                                    <CheckBox Content="Sunday" x:Name="SundayCheck" Foreground="White" Margin="0,0,18,10"/>
                                </WrapPanel>

                                <TextBlock Text="Default lesson window" Style="{StaticResource SectionTitle}"/>
                                <WrapPanel Margin="0,4,0,10">
                                    <StackPanel Margin="0,0,18,10">
                                        <TextBlock Text="From" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="StartHour" Width="140" MinHeight="36" Background="#102040" Foreground="Black" BorderBrush="#00E0FF"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,18,10">
                                        <TextBlock Text="To" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="EndHour" Width="140" MinHeight="36" Background="#102040" Foreground="Black" BorderBrush="#00E0FF"/>
                                    </StackPanel>
                                </WrapPanel>

                                <Border Background="#0E1A2B" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                                    <TextBlock Text="Students can only book inside this weekly window, unless a special working day below overrides it."
                                               Foreground="#AAB7C8"
                                               TextWrapping="Wrap"
                                               LineHeight="20"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Blocked time">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,12,10">
                                    <TextBlock Text="Date" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="UnavailableDatePicker" Width="150"/>
                                </StackPanel>
                                <CheckBox x:Name="UnavailableAllDay" Content="All day" Foreground="White" Margin="0,24,12,10"/>
                                <StackPanel Margin="0,0,12,10">
                                    <TextBlock Text="From" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="UnavailableStartHour" Width="110" Background="#102040" Foreground="Black" BorderBrush="#00E0FF"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,10">
                                    <TextBlock Text="To" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="UnavailableEndHour" Width="110" Background="#102040" Foreground="Black" BorderBrush="#00E0FF"/>
                                </StackPanel>
                                <Button Content="Add block" Width="110" Height="36" Margin="0,20,0,10" Style="{StaticResource PrimaryButton}" Click="AddUnavailableDay_Click"/>
                            </WrapPanel>

                            <ListView x:Name="UnavailableDaysList"
                                      Grid.Row="1"
                                      Background="#102040"
                                      Foreground="White"
                                      BorderBrush="#00E0FF"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Date" DisplayMemberBinding="{Binding Date}" Width="160"/>
                                        <GridViewColumn Header="All day" DisplayMemberBinding="{Binding AllDay}" Width="80"/>
                                        <GridViewColumn Header="From" DisplayMemberBinding="{Binding StartTime}" Width="100"/>
                                        <GridViewColumn Header="To" DisplayMemberBinding="{Binding EndTime}" Width="100"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <Button Grid.Row="2" Content="Remove selected" Width="160" HorizontalAlignment="Left" Margin="0,12,0,0" Style="{StaticResource DangerButton}" Click="RemoveUnavailableDay_Click"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Special days">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,12,10">
                                    <TextBlock Text="Date" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="SpecialDatePicker" Width="150"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,10">
                                    <TextBlock Text="From" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="SpecialStartHour" Width="110" Background="#102040" Foreground="Black" BorderBrush="#00E0FF"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,10">
                                    <TextBlock Text="To" Foreground="#AAB7C8" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="SpecialEndHour" Width="110" Background="#102040" Foreground="Black" BorderBrush="#00E0FF"/>
                                </StackPanel>
                                <Button Content="Add day" Width="110" Height="36" Margin="0,20,0,10" Style="{StaticResource PrimaryButton}" Click="AddSpecialDay_Click"/>
                            </WrapPanel>

                            <ListView x:Name="SpecialDaysList"
                                      Grid.Row="1"
                                      Background="#102040"
                                      Foreground="White"
                                      BorderBrush="#00E0FF"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Date" DisplayMemberBinding="{Binding Date}" Width="160"/>
                                        <GridViewColumn Header="From" DisplayMemberBinding="{Binding StartTime}" Width="110"/>
                                        <GridViewColumn Header="To" DisplayMemberBinding="{Binding EndTime}" Width="110"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <Button Grid.Row="2" Content="Remove selected" Width="160" HorizontalAlignment="Left" Margin="0,12,0,0" Style="{StaticResource DangerButton}" Click="RemoveSpecialDay_Click"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <Button Grid.Row="2"
                    Content="Save availability"
                    Width="220"
                    Height="46"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0"
                    Style="{StaticResource SuccessButton}"
                    Click="SaveAvailability_Click"/>
        </Grid>

        <Frame x:Name="page" Grid.RowSpan="3" Panel.ZIndex="100"/>
    </Grid>
</Page>
