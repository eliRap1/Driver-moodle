<Page x:Class="driver_client.TeacherConfirmPayments"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="TeacherConfirmPayments"
      Background="#0E1A2B">

    <Grid Margin="20">
        <!-- Background -->
        <Image Source="/picture/background.png"
               Stretch="UniformToFill"
               Opacity="0.06"
               Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Confirm Student Payments"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#00E0FF"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Summary -->
            <Border Grid.Row="1" Background="#1B2D47" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Pending Confirmations: " FontSize="16" Foreground="LightGray" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PendingCountText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#F39C12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Payments List -->
            <Border Grid.Row="2" Background="#1B2D47" CornerRadius="10" Padding="15">
                <DockPanel>
                    <TextBlock Text="Lessons Awaiting Payment Confirmation"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#00E0FF"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,15"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PaymentsPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Back Button -->
            <Button Grid.Row="3"
                    Content="Back"
                    Width="100" Height="40"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Left"
                    Background="#00E0FF"
                    Foreground="Black"
                    FontWeight="Bold"
                    BorderBrush="#00C0CC"
                    Cursor="Hand"
                    Click="Back_Click"/>
        </Grid>

        <Frame x:Name="page" Panel.ZIndex="100" Margin="-20,-20,-20,-20"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</Page>
