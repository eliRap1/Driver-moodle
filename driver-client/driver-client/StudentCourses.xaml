<Page x:Class="driver_client.StudentCourses"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:driver_client"
      mc:Ignorable="d"
      Title="StudentCourses"
      Background="#0E1A2B"
      d:DesignHeight="600" d:DesignWidth="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Background image -->
        <Image Source="/picture/background.png"
               Stretch="UniformToFill"
               Opacity="0.06"
               Panel.ZIndex="0"
               Grid.RowSpan="3"/>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20,20,20,10" Panel.ZIndex="1">
            <TextBlock Text="Learning Courses"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#00E0FF"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Select a course to view modules and track your progress"
                       FontSize="14"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Courses List -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="20,10"
                      Panel.ZIndex="1">
            <ItemsControl x:Name="CoursesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1B2D47"
                                CornerRadius="10"
                                Margin="0,0,0,15"
                                BorderBrush="#00E0FF"
                                BorderThickness="1"
                                Padding="20"
                                Cursor="Hand"
                                MouseLeftButtonUp="Course_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Course Name -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding CourseName}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#00E0FF"/>

                                <!-- Progress Circle -->
                                <Grid Grid.Row="0" Grid.Column="1"
                                      Grid.RowSpan="3"
                                      Width="80" Height="80"
                                      Margin="10,0,0,0">
                                    <Ellipse Stroke="#2A3F5F" StrokeThickness="6"/>
                                    <Ellipse Stroke="#00E0FF" StrokeThickness="6"
                                             StrokeDashArray="{Binding ProgressDash}"
                                             StrokeDashCap="Round"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ProgressText}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Course Description -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{Binding Description}"
                                           FontSize="14"
                                           Foreground="#CCCCCC"
                                           TextWrapping="Wrap"
                                           Margin="0,8,20,0"/>

                                <!-- Module Count -->
                                <StackPanel Grid.Row="2" Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,12,0,0">
                                    <TextBlock Text="{Binding CompletedModules}"
                                               FontSize="14"
                                               Foreground="#27AE60"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text=" / "
                                               FontSize="14"
                                               Foreground="#888888"/>
                                    <TextBlock Text="{Binding TotalModules}"
                                               FontSize="14"
                                               Foreground="#888888"/>
                                    <TextBlock Text=" modules completed"
                                               FontSize="14"
                                               Foreground="#888888"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyStatePanel"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    Panel.ZIndex="1">
            <TextBlock Text="No courses available yet"
                       FontSize="20"
                       Foreground="#888888"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Check back later for new learning materials"
                       FontSize="14"
                       Foreground="#666666"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Back Button -->
        <Button Grid.Row="2"
                Content="Back to Dashboard"
                HorizontalAlignment="Left"
                Margin="20,10,20,20"
                Padding="20,10"
                Background="#00E0FF"
                Foreground="Black"
                FontSize="14"
                FontWeight="Bold"
                BorderBrush="#00C0CC"
                Cursor="Hand"
                Click="BackButton_Click"
                Panel.ZIndex="1"/>

        <!-- Navigation Frame -->
        <Frame x:Name="page" Panel.ZIndex="100" Grid.RowSpan="3"/>
    </Grid>
</Page>
