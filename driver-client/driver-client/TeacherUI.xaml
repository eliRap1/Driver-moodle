<Page x:Class="driver_client.TeacherUI"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:driver_client"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="900"
      Title="TeacherUI"
      Background="#0E1A2B">

    <Grid Margin="20">
        <!-- Background image -->
        <Image Source="/picture/background1.png"
               Stretch="UniformToFill"
               Opacity="0.06"
               Panel.ZIndex="0"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Panel.ZIndex="1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header with Welcome and Notifications -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Welcome back,"
                                   FontSize="16"
                                   Foreground="#888"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="teacherName"
                                       Text="Teacher"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#00E0FF"/>
                            <Border x:Name="AdminBadge"
                                    Background="#E74C3C"
                                    CornerRadius="5"
                                    Padding="10,3"
                                    Margin="15,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <TextBlock Text="ADMIN"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Notification Bell -->
                    <Button Grid.Column="1"
                            Click="Notifications_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="View Notifications"
                            Width="50" Height="50">
                        <Grid>
                            <TextBlock Text="&#128276;" FontSize="28" Foreground="#00E0FF"/>
                            <Border x:Name="NotificationBadge"
                                    Style="{StaticResource NotificationBadge}"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="NotificationCount"
                                           Text="0"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                </Grid>

                <!-- Quick Stats Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#128101;" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalStudentsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00E0FF" HorizontalAlignment="Center"/>
                            <TextBlock Text="Students" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#128197;" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TodayLessonsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                            <TextBlock Text="Today" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#128176;" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="PendingPaymentsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#F39C12" HorizontalAlignment="Center"/>
                            <TextBlock Text="Unpaid" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardBorder}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#128276;" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="UnreadNotificationsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#E74C3C" HorizontalAlignment="Center"/>
                            <TextBlock Text="Unread" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Action Buttons Grid -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Admin Dashboard Button (Only for admin) -->
                    <Button x:Name="AdminDashboardBtn"
                            Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="&#128737; Admin Dashboard"
                            Click="AdminDashboard_Click"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderBrush="#C0392B"
                            FontWeight="Bold"
                            FontSize="16"
                            Height="45"
                            Cursor="Hand"
                            Margin="5"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Row 1 -->
                    <Button Grid.Row="1" Grid.Column="0"
                            Content="&#128101;  My Students"
                            Click="Students_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="5"/>

                    <Button Grid.Row="1" Grid.Column="1"
                            Content="&#128197;  Lesson Schedule"
                            Click="Schedule_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="5"/>

                    <!-- Row 2 -->
                    <Button Grid.Row="2" Grid.Column="0"
                            Content="&#128198;  Calendar"
                            Click="Calendar_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="5"/>

                    <Button Grid.Row="2" Grid.Column="1"
                            Content="&#128176;  Payment Reports"
                            Click="PaymentReports_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="5"/>

                    <!-- Row 3 -->
                    <Button Grid.Row="3" Grid.Column="0"
                            Content="&#10003;  Confirm Payments"
                            Click="ConfirmPayments_Click"
                            Style="{StaticResource SuccessButton}"
                            Margin="5"/>

                    <Button Grid.Row="3" Grid.Column="1"
                            Content="&#128276;  Notifications"
                            Click="Notifications_Click"
                            Style="{StaticResource WarningButton}"
                            Margin="5"/>

                    <!-- Row 4 -->
                    <Button Grid.Row="4" Grid.Column="0"
                            Content="&#128172;  Chat"
                            Click="Chat_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="5"/>

                    <Button Grid.Row="4" Grid.Column="1"
                            Content="&#127915;  Support Tickets"
                            Click="SupportTickets_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="5"/>

                    <!-- Row 5 - Manage Courses -->
                    <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="&#128218;  Manage Courses"
                            Click="ManageCourses_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="5"/>

                    <!-- Row 6 - Settings -->
                    <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="&#9881;  Settings"
                            Click="Settings_Click"
                            Background="#9B59B6"
                            Foreground="White"
                            BorderBrush="#8E44AD"
                            FontWeight="Bold"
                            FontSize="16"
                            Height="45"
                            Cursor="Hand"
                            Margin="5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#8E44AD"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Logout -->
                    <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="&#128682;  Logout"
                            Click="Logout_Click"
                            Style="{StaticResource DangerButton}"
                            Margin="5,20,5,5"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Navigation Frame -->
        <Frame x:Name="page" Panel.ZIndex="100" Margin="-19,-21,-21,-19"/>
    </Grid>
</Page>
