<Page x:Class="driver_client.Teacher_Schedule"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1040"
      Background="#0E1A2B">

    <Grid>
        <Image Source="/picture/background.png"
               Stretch="UniformToFill"
               Opacity="0.05"
               Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1" Margin="24" MaxWidth="1180" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="Back"
                        Style="{StaticResource PrimaryButton}"
                        Width="96"
                        Height="38"
                        FontSize="14"
                        Margin="0"
                        Click="Back_Click"/>

                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <TextBlock Text="Lesson schedule"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#00E0FF"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Review upcoming bookings, filter a single day, and mark payments from one place."
                               FontSize="14"
                               Foreground="#AAB7C8"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <WrapPanel Grid.Row="1" Margin="0,0,0,18">
                <Border Style="{StaticResource CardBorder}" Width="190" Margin="0,0,10,10">
                    <StackPanel>
                        <TextBlock Text="Upcoming" Foreground="#AAB7C8"/>
                        <TextBlock x:Name="UpcomingCountText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#00E0FF"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Width="190" Margin="0,0,10,10">
                    <StackPanel>
                        <TextBlock Text="Selected day" Foreground="#AAB7C8"/>
                        <TextBlock x:Name="DayCountText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Width="190" Margin="0,0,10,10">
                    <StackPanel>
                        <TextBlock Text="Unpaid" Foreground="#AAB7C8"/>
                        <TextBlock x:Name="UnpaidCountText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#F39C12"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <TabControl Background="#14273D"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="10">
                    <TabItem Header="Upcoming">
                        <Grid Margin="0,10,0,0">
                            <ListView x:Name="UpcomingLessons"
                                      Background="#1B2D47"
                                      Foreground="White"
                                      BorderThickness="0"
                                      SelectionMode="Single"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Student" Width="190" DisplayMemberBinding="{Binding StudentName}"/>
                                        <GridViewColumn Header="Date" Width="110" DisplayMemberBinding="{Binding Date}"/>
                                        <GridViewColumn Header="Time" Width="90" DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="Status" Width="110">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Payment" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding PaidButtonText}" Background="#2980B9" Foreground="White" Padding="8,3" CommandParameter="{Binding}" Click="TogglePaid_Click"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Cancel" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Cancel" Background="#E74C3C" Foreground="White" Padding="8,3" CommandParameter="{Binding}" Visibility="{Binding CanCancel}" Click="CancelLesson_Click"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </TabItem>

                    <TabItem Header="By day">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Date" VerticalAlignment="Center" FontSize="14" Foreground="#AAB7C8" Margin="0,0,10,0"/>
                                <DatePicker x:Name="LessonDatePicker" Width="200" Background="White" Foreground="Black" SelectedDateChanged="LessonDatePicker_SelectedDateChanged"/>
                            </StackPanel>

                            <ListView x:Name="DayLessons"
                                      Grid.Row="1"
                                      Background="#1B2D47"
                                      Foreground="White"
                                      BorderThickness="0"
                                      SelectionMode="Single"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Student" Width="190" DisplayMemberBinding="{Binding StudentName}"/>
                                        <GridViewColumn Header="Time" Width="90" DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="Status" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Payment" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding PaidButtonText}" Background="#2980B9" Foreground="White" Padding="8,3" CommandParameter="{Binding}" Click="TogglePaid_Click"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </TabItem>

                    <TabItem Header="History">
                        <ListView x:Name="HistoryLessons"
                                  Background="#1B2D47"
                                  Foreground="White"
                                  BorderThickness="0"
                                  Margin="0,10,0,0"
                                  SelectionMode="Single"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Student" Width="190" DisplayMemberBinding="{Binding StudentName}"/>
                                    <GridViewColumn Header="Date" Width="110" DisplayMemberBinding="{Binding Date}"/>
                                    <GridViewColumn Header="Time" Width="90" DisplayMemberBinding="{Binding Time}"/>
                                    <GridViewColumn Header="Status" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Payment" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding PaidButtonText}" Background="#2980B9" Foreground="White" Padding="8,3" CommandParameter="{Binding}" Click="TogglePaid_Click"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>
                </TabControl>
            </Border>

            <TextBlock Grid.Row="3"
                       Text="This page refreshes every few seconds while it is open."
                       Foreground="#7F8DA3"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>
        </Grid>

        <Frame x:Name="page" Panel.ZIndex="100"/>
    </Grid>
</Page>
