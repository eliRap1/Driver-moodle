<Page x:Class="driver_client.ViewLessons"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:driver_client"
      mc:Ignorable="d"
      Title="ViewLessons"
      Background="#0E1A2B"
      d:DesignHeight="450" d:DesignWidth="800">

    <Page.Resources>
        <local:ImgConventer x:Key="ImgConventer"/>

        <Style x:Key="DarkLessonCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0E1A2B"/>
                    <Setter Property="Foreground" Value="#00E0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkLessonRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="#1B2D47"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#1A2636"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243A55"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0E1A2B"/>
                    <Setter Property="Foreground" Value="#00E0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkLessonHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#00E0FF"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Background="#0E1A2B" Margin="-4,3,-6,-2">
        <Grid.RowDefinitions>
            <RowDefinition Height="57*"/>
            <RowDefinition Height="455*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Your Driving Lessons"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#00E0FF"
                   HorizontalAlignment="Center"
                   Margin="0" Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Upcoming Lessons -->
            <Border Grid.Column="0" Padding="10" Background="#1A2636" CornerRadius="10" BorderBrush="#00E0FF" BorderThickness="1" Margin="0,0,5,0">
                <DockPanel>
                    <TextBlock Text="Upcoming Lessons"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#00E0FF"
                               Margin="0,0,0,10"
                               DockPanel.Dock="Top"/>
                    <DataGrid x:Name="UpcomingLessonsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Background="#1A2636"
                              RowBackground="#1B2D47"
                              AlternatingRowBackground="#1A2636"
                              Foreground="White"
                              FontSize="14"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              ColumnHeaderHeight="30"
                              BorderThickness="0"
                              CellStyle="{StaticResource DarkLessonCell}"
                              RowStyle="{StaticResource DarkLessonRow}"
                              ColumnHeaderStyle="{StaticResource DarkLessonHeader}"
                              AlternationCount="2"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding LessonId}" Width="50"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80"/>
                            <DataGridTemplateColumn Header="Paid" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Width="16" Height="16"
                                               Source="{Binding Paid, Converter={StaticResource ImgConventer}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Completed Lessons -->
            <Border Grid.Column="1" Padding="10" Background="#1A2636" CornerRadius="10" BorderBrush="#27AE60" BorderThickness="1" Margin="5,0,0,0">
                <DockPanel>
                    <TextBlock Text="Completed Lessons"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#27AE60"
                               Margin="0,0,0,10"
                               DockPanel.Dock="Top"/>
                    <DataGrid x:Name="CompletedLessonsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Background="#1A2636"
                              RowBackground="#1B2D47"
                              AlternatingRowBackground="#1A2636"
                              Foreground="White"
                              FontSize="14"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              ColumnHeaderHeight="30"
                              BorderThickness="0"
                              CellStyle="{StaticResource DarkLessonCell}"
                              RowStyle="{StaticResource DarkLessonRow}"
                              ColumnHeaderStyle="{StaticResource DarkLessonHeader}"
                              AlternationCount="2"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding LessonId}" Width="50"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80"/>
                            <DataGridTemplateColumn Header="Paid" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Width="16" Height="16"
                                               Source="{Binding Paid, Converter={StaticResource ImgConventer}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Back Button -->
        <Button Content="Back"
                Grid.Row="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Padding="10,5"
                Margin="0,20,0,0"
                Width="80"
                Height="30"
                Background="#00E0FF"
                Foreground="Black"
                FontSize="16"
                FontWeight="SemiBold"
                BorderBrush="#00C0CC"
                BorderThickness="1"
                Cursor="Hand"
                Click="BackButton_Click"/>

        <Frame x:Name="page" Panel.ZIndex="100" Grid.RowSpan="3"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</Page>
