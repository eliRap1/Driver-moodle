<Page x:Class="driver_client.StudentNotifications"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Notifications"
      Background="#0E1A2B">

    <Grid>
        <Frame x:Name="page" Panel.ZIndex="100"/>

        <!-- Background -->
        <Image Source="/picture/background.png"
               Stretch="UniformToFill"
               Opacity="0.06"
               Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1" Margin="20" MaxWidth="1080" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&#8592; Back"
                        Click="Back_Click"
                        Background="Transparent"
                        Foreground="#00E0FF"
                        BorderBrush="#00E0FF"
                        FontSize="14"
                        Padding="15,8"
                        Cursor="Hand"/>

                <TextBlock Grid.Column="1"
                           Text="Notifications"
                           Style="{StaticResource PageTitle}"
                           HorizontalAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="Mark All Read"
                        Click="MarkAllRead_Click"
                        Style="{StaticResource SuccessButton}"
                        Width="130"
                        Height="35"
                        FontSize="12"/>
            </Grid>

            <!-- Send Message to Teacher -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,15" BorderBrush="#27AE60">
                <Expander Header="Send Message to Teacher" Foreground="White" IsExpanded="False">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="1" Margin="0,0,10,10">
                            <TextBlock Text="Title" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="TitleTextBox"
                                     Background="#1A2636"
                                     Foreground="White"
                                     Height="35"
                                     Padding="10,8"
                                     BorderBrush="#00E0FF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,0">
                            <TextBlock Text="Message" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="MessageTextBox"
                                     Background="#1A2636"
                                     Foreground="White"
                                     Height="60"
                                     Padding="10,8"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     BorderBrush="#00E0FF"/>
                        </StackPanel>

                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                Content="Send"
                                Click="SendMessage_Click"
                                Style="{StaticResource SuccessButton}"
                                Width="100"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Expander>
            </Border>

            <!-- Stats Cards -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" BorderBrush="#F39C12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="UnreadCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#F39C12" HorizontalAlignment="Center"/>
                        <TextBlock Text="Unread" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}" BorderBrush="#00E0FF">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TotalCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#00E0FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Total" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}" BorderBrush="#27AE60">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="MessagesCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                        <TextBlock Text="Messages" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Notifications List -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="All Notifications" Style="{StaticResource SectionTitle}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="NotificationsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,5" Padding="15" CornerRadius="8"
                                            Background="{Binding BackgroundColor}"
                                            BorderThickness="0,0,0,3"
                                            BorderBrush="{Binding TypeColor}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <Border Grid.Column="0"
                                                    Width="40" Height="40"
                                                    CornerRadius="20"
                                                    Background="{Binding TypeColor}"
                                                    Margin="0,0,15,0">
                                                <TextBlock Text="{Binding TypeIcon}"
                                                           FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="Bold"
                                                               FontSize="14"
                                                               Foreground="White"/>
                                                    <Border Visibility="{Binding UnreadBadgeVisibility}"
                                                            Background="#F39C12"
                                                            CornerRadius="3"
                                                            Padding="5,1"
                                                            Margin="10,0,0,0">
                                                        <TextBlock Text="NEW" FontSize="9" Foreground="Black" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Message}"
                                                           FontSize="12"
                                                           Foreground="#AAA"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="620"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <TextBlock Text="From: " FontSize="11" Foreground="#666"/>
                                                    <TextBlock Text="{Binding SenderName}" FontSize="11" Foreground="#00E0FF"/>
                                                    <TextBlock Text=" | " FontSize="11" Foreground="#666"/>
                                                    <TextBlock Text="{Binding FormattedDate}" FontSize="11" Foreground="#666"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#10003;"
                                                        Tag="{Binding Id}"
                                                        Click="MarkRead_Click"
                                                        Visibility="{Binding MarkReadVisibility}"
                                                        Background="#27AE60"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Width="30" Height="30"
                                                        FontSize="14"
                                                        Cursor="Hand"
                                                        ToolTip="Mark as Read"
                                                        Margin="5,0"/>
                                                <Button Content="&#10006;"
                                                        Tag="{Binding Id}"
                                                        Click="Delete_Click"
                                                        Background="#E74C3C"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Width="30" Height="30"
                                                        FontSize="14"
                                                        Cursor="Hand"
                                                        ToolTip="Delete"
                                                        Margin="5,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyState"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Grid.Row="1">
                        <TextBlock Text="&#128276;" FontSize="48" HorizontalAlignment="Center" Foreground="#444"/>
                        <TextBlock Text="No notifications yet" FontSize="16" Foreground="#666" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="You'll see messages from your teacher here" FontSize="12" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Refresh Button -->
            <Button Grid.Row="4"
                    Content="&#8635; Refresh"
                    Click="Refresh_Click"
                    Style="{StaticResource PrimaryButton}"
                    Width="150"
                    Margin="0,15,0,0"/>
        </Grid>
    </Grid>
</Page>
