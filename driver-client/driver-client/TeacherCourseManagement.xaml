<Page x:Class="driver_client.TeacherCourseManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Manage Courses"
      Background="#0E1A2B">

    <Grid>
        <Frame x:Name="page" Panel.ZIndex="100"/>

        <Image Source="/picture/background.png"
               Stretch="UniformToFill"
               Opacity="0.06"
               Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&#8592; Back"
                        Click="Back_Click"
                        Background="Transparent"
                        Foreground="#00E0FF"
                        BorderBrush="#00E0FF"
                        FontSize="14"
                        Padding="15,8"
                        Cursor="Hand"/>

                <TextBlock Grid.Column="1"
                           Text="Manage Courses"
                           Style="{StaticResource PageTitle}"
                           HorizontalAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="+ New Course"
                        Click="NewCourse_Click"
                        Style="{StaticResource SuccessButton}"
                        Width="130"
                        Height="35"
                        FontSize="12"/>
            </Grid>

            <!-- New/Edit Course Form -->
            <Border x:Name="CourseFormPanel" Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,15" BorderBrush="#00E0FF" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="New Course" FontSize="18" FontWeight="Bold" Foreground="#00E0FF" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="Course Name" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="CourseNameBox"
                                     Background="#1A2636"
                                     Foreground="White"
                                     Height="35"
                                     Padding="10,8"
                                     BorderBrush="#00E0FF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="Display Order" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="DisplayOrderBox"
                                     Background="#1A2636"
                                     Foreground="White"
                                     Height="35"
                                     Padding="10,8"
                                     BorderBrush="#00E0FF"
                                     Text="1"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                            <TextBlock Text="Description" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="CourseDescBox"
                                     Background="#1A2636"
                                     Foreground="White"
                                     Height="60"
                                     Padding="10,8"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     BorderBrush="#00E0FF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="IsActiveCheck" IsChecked="True" VerticalAlignment="Center"/>
                            <TextBlock Text=" Active" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Save"
                                    Click="SaveCourse_Click"
                                    Style="{StaticResource SuccessButton}"
                                    Width="100" Height="35"
                                    Margin="0,0,10,0"/>
                            <Button Content="Cancel"
                                    Click="CancelForm_Click"
                                    Style="{StaticResource DangerButton}"
                                    Width="100" Height="35"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Courses List with Modules -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl x:Name="CoursesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,15" Padding="15" CornerRadius="8"
                                        Background="#0F1E30"
                                        BorderThickness="1"
                                        BorderBrush="#1A3A5C">
                                    <StackPanel>
                                        <!-- Course Header -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding CourseName}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="#00E0FF"/>
                                                    <Border Margin="10,0,0,0" Padding="6,2"
                                                            CornerRadius="4"
                                                            Background="{Binding StatusColor}">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12" Foreground="#888"
                                                           TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                <TextBlock FontSize="11" Foreground="#666" Margin="0,3,0,0">
                                                    <Run Text="Order: "/><Run Text="{Binding DisplayOrder}"/>
                                                    <Run Text=" | Modules: "/><Run Text="{Binding ModuleCount}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                <Button Content="Edit"
                                                        Tag="{Binding CourseId}"
                                                        Click="EditCourse_Click"
                                                        Background="#3498DB"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Width="60" Height="30"
                                                        FontSize="12"
                                                        Cursor="Hand"
                                                        Margin="5,0"/>
                                                <Button Content="Add Module"
                                                        Tag="{Binding CourseId}"
                                                        Click="AddModule_Click"
                                                        Background="#27AE60"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Width="90" Height="30"
                                                        FontSize="12"
                                                        Cursor="Hand"
                                                        Margin="5,0"/>
                                                <Button Content="Deactivate"
                                                        Tag="{Binding CourseId}"
                                                        Click="DeactivateCourse_Click"
                                                        Background="#E74C3C"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Width="80" Height="30"
                                                        FontSize="12"
                                                        Cursor="Hand"
                                                        Margin="5,0"
                                                        Visibility="{Binding DeactivateVisibility}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Modules List -->
                                        <ItemsControl ItemsSource="{Binding Modules}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,3" Padding="10" CornerRadius="5"
                                                            Background="#1A2636"
                                                            BorderThickness="0,0,0,2"
                                                            BorderBrush="#1A3A5C">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Grid.Column="0" Width="28" Height="28"
                                                                    CornerRadius="14"
                                                                    Background="#1A3A5C"
                                                                    Margin="0,0,10,0">
                                                                <TextBlock Text="{Binding OrderIndex}"
                                                                           FontSize="12"
                                                                           Foreground="#00E0FF"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ModuleName}"
                                                                           FontSize="13" Foreground="White"/>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding ContentType}"
                                                                               FontSize="10" Foreground="#00E0FF"/>
                                                                    <TextBlock FontSize="10" Foreground="#666" Margin="10,0,0,0">
                                                                        <Run Text="{Binding DurationMinutes}"/>
                                                                        <Run Text=" min"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding RequiredText}"
                                                                               FontSize="10" Foreground="#F39C12"
                                                                               Margin="10,0,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                <Button Content="&#9998;"
                                                                        Tag="{Binding ModuleId}"
                                                                        Click="EditModule_Click"
                                                                        Background="#3498DB"
                                                                        Foreground="White"
                                                                        BorderThickness="0"
                                                                        Width="28" Height="28"
                                                                        FontSize="12"
                                                                        Cursor="Hand"
                                                                        ToolTip="Edit Module"
                                                                        Margin="3,0"/>
                                                                <Button Content="&#10006;"
                                                                        Tag="{Binding ModuleId}"
                                                                        Click="DeleteModule_Click"
                                                                        Background="#E74C3C"
                                                                        Foreground="White"
                                                                        BorderThickness="0"
                                                                        Width="28" Height="28"
                                                                        FontSize="12"
                                                                        Cursor="Hand"
                                                                        ToolTip="Delete Module"
                                                                        Margin="3,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyState"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                Margin="0,50,0,0">
                        <TextBlock Text="&#128218;" FontSize="48" HorizontalAlignment="Center" Foreground="#444"/>
                        <TextBlock Text="No courses yet" FontSize="16" Foreground="#666" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="Click 'New Course' to create your first course" FontSize="12" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Module Form Overlay -->
        <Grid x:Name="ModuleFormOverlay" Panel.ZIndex="50" Visibility="Collapsed"
              Background="#CC000000">
            <Border Width="500" VerticalAlignment="Center"
                    Background="#0E1A2B"
                    BorderBrush="#00E0FF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20">
                <StackPanel>
                    <TextBlock x:Name="ModuleFormTitle" Text="Add Module" FontSize="18" FontWeight="Bold" Foreground="#00E0FF" Margin="0,0,0,15"/>

                    <TextBlock Text="Module Name" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="ModuleNameBox"
                             Background="#1A2636" Foreground="White"
                             Height="35" Padding="10,8"
                             BorderBrush="#00E0FF"/>

                    <TextBlock Text="Description" Foreground="#888" FontSize="12" Margin="0,10,0,5"/>
                    <TextBox x:Name="ModuleDescBox"
                             Background="#1A2636" Foreground="White"
                             Height="60" Padding="10,8"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             BorderBrush="#00E0FF"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Content Type" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox x:Name="ContentTypeCombo"
                                      Background="#1A2636" Foreground="Black"
                                      Height="30">
                                <ComboBoxItem Content="Text" IsSelected="True"/>
                                <ComboBoxItem Content="Video"/>
                                <ComboBoxItem Content="Quiz"/>
                                <ComboBoxItem Content="Assignment"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Duration (minutes)" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="DurationBox"
                                     Background="#1A2636" Foreground="White"
                                     Height="30" Padding="10,5"
                                     BorderBrush="#00E0FF"
                                     Text="30"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Order Index" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="OrderIndexBox"
                                     Background="#1A2636" Foreground="White"
                                     Height="30" Padding="10,5"
                                     BorderBrush="#00E0FF"
                                     Text="1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="IsRequiredCheck" IsChecked="True" VerticalAlignment="Center"/>
                                <TextBlock Text=" Required Module" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Save Module"
                                Click="SaveModule_Click"
                                Style="{StaticResource SuccessButton}"
                                Width="120" Height="35"
                                Margin="0,0,10,0"/>
                        <Button Content="Cancel"
                                Click="CancelModuleForm_Click"
                                Style="{StaticResource DangerButton}"
                                Width="100" Height="35"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
