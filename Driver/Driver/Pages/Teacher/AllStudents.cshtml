@page
@model AllStudentsModel
@{
    ViewData["Title"] = Model.IsAdmin ? "All Students" : "My Students";
    Layout = "_Layout";
}

<h1 style="color: #00E0FF; text-align: center; margin-bottom: 30px;">
    📚 @(Model.IsAdmin ? "All Students Database" : "My Students")
</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Students != null && Model.Students.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Teacher ID</th>
                    <th>Confirmed</th>
                    <th>Pricing</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model.Students)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td>@student.Username</td>
                        <td>@student.Email</td>
                        <td>@student.Phone</td>
                        <td>@student.TeacherId</td>
                        <td>
                            @if (student.Confirmed)
                            {
                                <span class="badge bg-success">✓ Confirmed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">⏳ Pending</span>
                            }
                        </td>
                        <td>
                            <form method="post" asp-page-handler="SetPrice" class="d-inline-flex gap-1 mb-1">
                                <input type="hidden" name="studentId" value="@student.Id" />
                                <input type="number" name="price" class="form-control form-control-sm"
                                       style="width:80px" placeholder="₪" min="50" max="10000" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Set</button>
                            </form>
                            <form method="post" asp-page-handler="SetDiscount" class="d-inline-flex gap-1">
                                <input type="hidden" name="studentId" value="@student.Id" />
                                <input type="number" name="discountPercent" class="form-control form-control-sm"
                                       style="width:65px" placeholder="%" min="0" max="100" />
                                <button type="submit" class="btn btn-sm btn-outline-success">%Off</button>
                            </form>
                            <small class="text-muted d-block">
                                Effective: ₪@(Model.EffectivePrices.ContainsKey(student.Id) ? Model.EffectivePrices[student.Id] : 200)
                            </small>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="alert alert-info mt-3">
        <strong>Total Students:</strong> @Model.Students.Count
    </div>
}
else
{
    <div class="alert alert-warning text-center">
        <h4>No students found in the database.</h4>
    </div>
}

<div class="text-center mt-4">
    <a asp-page="/Teacher/TeacherHome" class="btn btn-primary">← Back to Dashboard</a>
</div>