@page
@model PaymentReportsModel
@{
    ViewData["Title"] = "Payment Reports";
    Layout = "_Layout";
}

<div class="text-center mb-4">
    <h1 class="display-5" style="color: #00E0FF;">Payment Reports</h1>
    <p class="lead">Track your earnings and payment history</p>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center" style="background-color: #1B2D47; border: 2px solid #27AE60;">
            <div class="card-body">
                <h3 style="color: #27AE60;">@Model.TotalEarnings NIS</h3>
                <p class="mb-0">Total Earnings</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center" style="background-color: #1B2D47; border: 2px solid #00E0FF;">
            <div class="card-body">
                <h3 style="color: #00E0FF;">@Model.ThisMonthEarnings NIS</h3>
                <p class="mb-0">This Month</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center" style="background-color: #1B2D47; border: 2px solid #F39C12;">
            <div class="card-body">
                <h3 style="color: #F39C12;">@Model.PendingAmount NIS</h3>
                <p class="mb-0">Pending</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center" style="background-color: #1B2D47; border: 2px solid #E74C3C;">
            <div class="card-body">
                <h3 style="color: #E74C3C;">@Model.StudentsWithDebt</h3>
                <p class="mb-0">Students with Debt</p>
            </div>
        </div>
    </div>
</div>

<!-- Recent Payments -->
<div class="card" style="background-color: #1B2D47; border: 2px solid #00E0FF;">
    <div class="card-header text-center" style="background-color: #00E0FF; color: black;">
        <h5 class="mb-0">Recent Payments</h5>
    </div>
    <div class="card-body">
        @if (Model.RecentPayments.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Student</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Method</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.RecentPayments)
                        {
                            <tr>
                                <td>
                                    @if (payment.IsPaid)
                                    {
                                        <span class="text-success fs-5">&#10003;</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning fs-5">&#9203;</span>
                                    }
                                </td>
                                <td>@payment.StudentName</td>
                                <td>@payment.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="color: @(payment.IsPaid ? "#27AE60" : "#F39C12"); font-weight: bold;">
                                    @payment.Amount NIS
                                </td>
                                <td>@payment.PaymentMethod</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-center text-muted">No payments recorded yet.</p>
        }
    </div>
</div>

<!-- Students with Outstanding Payments -->
<div class="card mt-4" style="background-color: #1B2D47; border: 2px solid #E74C3C;">
    <div class="card-header text-center" style="background-color: #E74C3C; color: white;">
        <h5 class="mb-0">Students with Outstanding Payments</h5>
    </div>
    <div class="card-body">
        @if (Model.DebtStudents.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Unpaid Lessons</th>
                            <th>Total Owed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model.DebtStudents)
                        {
                            <tr>
                                <td>@student.StudentName</td>
                                <td>@student.UnpaidLessons</td>
                                <td style="color: #E74C3C; font-weight: bold;">@student.TotalOwed NIS</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-center text-success">All students are up to date with payments!</p>
        }
    </div>
</div>

<div class="text-center mt-4">
    <a asp-page="/Teacher/ConfirmPayments" class="btn btn-success">Confirm Payments</a>
    <a asp-page="/Teacher/TeacherHome" class="btn btn-outline-light">Back to Dashboard</a>
</div>
