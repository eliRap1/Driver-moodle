@page
@model Driver.Pages.Admin.ManageUsersModel
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_Layout";
}

<h1 style="color: #00E0FF; text-align: center; margin-bottom: 30px;">
    Manage Users
</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h3 style="color: #00E0FF; margin-bottom: 15px;">Students</h3>

@if (Model.Students != null && Model.Students.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Teacher ID</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model.Students)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td>@student.Username</td>
                        <td>@student.Email</td>
                        <td>@student.Phone</td>
                        <td>@student.TeacherId</td>
                        <td>
                            <button class="btn btn-sm btn-primary" onclick="showEditStudent(@student.Id, '@student.Email', '@student.Phone', @student.TeacherId)">Edit</button>
                            <button class="btn btn-sm btn-warning" onclick="showResetPwd(@student.Id, 'Student')">Reset PWD</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="alert alert-info mt-3">
        <strong>Total Students:</strong> @Model.Students.Count
    </div>
}
else
{
    <div class="alert alert-warning text-center">
        <h4>No students found.</h4>
    </div>
}

<h3 style="color: #00E0FF; margin-top: 30px; margin-bottom: 15px;">Teachers</h3>

@if (Model.Teachers != null && Model.Teachers.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var teacher in Model.Teachers)
                {
                    <tr>
                        <td>@teacher.Id</td>
                        <td>@teacher.Username</td>
                        <td>@teacher.Email</td>
                        <td>
                            <button class="btn btn-sm btn-warning" onclick="showResetPwd(@teacher.Id, 'Teacher')">Reset PWD</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="alert alert-info mt-3">
        <strong>Total Teachers:</strong> @Model.Teachers.Count
    </div>
}
else
{
    <div class="alert alert-warning text-center">
        <h4>No teachers found.</h4>
    </div>
}

<div class="text-center mt-4">
    <a asp-page="/Teacher/TeacherHome" class="btn btn-primary">← Back to Dashboard</a>
</div>

<div class="modal fade" id="editStudentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background-color: #1A2636; color: white;">
            <div class="modal-header" style="border-color: #00E0FF;">
                <h5 class="modal-title" style="color: #00E0FF;">Edit Student</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="UpdateStudent">
                <div class="modal-body">
                    <input type="hidden" name="studentId" id="editStudentId" />
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" id="editEmail" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input type="text" class="form-control" name="phone" id="editPhone" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teacher ID</label>
                        <input type="number" class="form-control" name="teacherId" id="editTeacherId" required />
                    </div>
                </div>
                <div class="modal-footer" style="border-color: #00E0FF;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="resetPwdModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background-color: #1A2636; color: white;">
            <div class="modal-header" style="border-color: #00E0FF;">
                <h5 class="modal-title" style="color: #00E0FF;">Reset Password</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="ResetPassword">
                <div class="modal-body">
                    <input type="hidden" name="userId" id="resetUserId" />
                    <input type="hidden" name="table" id="resetTable" />
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="password" class="form-control" name="newPassword" id="resetNewPassword" required minlength="4" />
                    </div>
                </div>
                <div class="modal-footer" style="border-color: #00E0FF;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Reset Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showEditStudent(id, email, phone, teacherId) {
            document.getElementById('editStudentId').value = id;
            document.getElementById('editEmail').value = email;
            document.getElementById('editPhone').value = phone;
            document.getElementById('editTeacherId').value = teacherId;
            new bootstrap.Modal(document.getElementById('editStudentModal')).show();
        }

        function showResetPwd(id, table) {
            document.getElementById('resetUserId').value = id;
            document.getElementById('resetTable').value = table;
            document.getElementById('resetNewPassword').value = '';
            new bootstrap.Modal(document.getElementById('resetPwdModal')).show();
        }
    </script>
}
